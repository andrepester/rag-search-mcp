# -- Local RAG Environment Variables ----------------------------------
# Copy this file to .env and adjust values as needed.
# All variables have sensible defaults; you only need to set the ones
# you want to override.
# Relative paths are resolved from the repository root.

# Directory containing documents to index (relative or absolute)
# RAG_DOCS_DIR=docs

# Directory for the Chroma vector index (relative or absolute)
# RAG_CHROMA_DIR=index

# Ollama API endpoint
# OLLAMA_HOST=http://127.0.0.1:11434

# Embedding model served by Ollama
# You can pin a specific model/version tag (recommended for reproducibility).
# Example: EMBED_MODEL=nomic-embed-text:latest
# EMBED_MODEL=nomic-embed-text

# Chroma collection name
# COLLECTION_NAME=docs

# Chunk size in characters for document splitting
# RAG_CHUNK_SIZE=1200

# Overlap in characters between consecutive chunks
# RAG_CHUNK_OVERLAP=200
