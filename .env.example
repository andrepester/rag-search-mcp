# HTTP endpoint exposed by rag-mcp on the host
RAG_HTTP_HOST=127.0.0.1
RAG_HTTP_PORT=8765

# Host paths mounted read-only into the rag-mcp container
HOST_DOCS_DIR=./data/docs
HOST_CODE_DIR=./data/code

# Host paths mounted read-write for persistent runtime data
HOST_INDEX_DIR=./data/index

# Shared Ollama endpoint used for embeddings. This stack does not start Ollama.
OLLAMA_HOST=
EMBED_MODEL=nomic-embed-text

# RAG runtime tuning
RAG_ENABLE_CODE_INGEST=true
RAG_CHROMA_TENANT=default_tenant
RAG_CHROMA_DATABASE=default_database
RAG_COLLECTION_NAME=rag
RAG_SCOPE_DEFAULT=all
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MAX_TOP_K=50
RAG_MAX_SEARCH_DISTANCE=0.50
RAG_INDEX_LIMIT=0
RAG_EMBED_CONCURRENCY=2
RAG_EMBED_BATCH_SIZE=16
RAG_EMBED_NUM_THREADS=0
RAG_REINDEX_TIMEOUT=60m

# Runtime observability logs from rag-mcp and rag-index
RAG_LOG_LEVEL=info
RAG_LOG_FORMAT=json
