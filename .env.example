# HTTP endpoint exposed by rag-mcp on the host
RAG_HTTP_PORT=8765

# Host paths mounted read-only into the rag-mcp container
HOST_DOCS_DIR=./data/docs
HOST_CODE_DIR=./data/code

# Optional Ollama host override for rag-mcp. Default is in-stack service name.
OLLAMA_HOST=http://ollama:11434
EMBED_MODEL=nomic-embed-text

# Optional host port published by the Ollama container
OLLAMA_PORT=11434

# RAG runtime tuning
RAG_ENABLE_CODE_INGEST=true
RAG_CHROMA_TENANT=default_tenant
RAG_CHROMA_DATABASE=default_database
RAG_COLLECTION_NAME=rag
RAG_SCOPE_DEFAULT=all
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MAX_TOP_K=50
